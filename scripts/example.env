# Template de credenciales para los scripts en scripts/
# Copialo a .env (en la raíz del repo) y completá los valores.
# NUNCA commitear con valores reales.

# ── CrowdStrike ─────────────────────────────────────────────────────────
# Falcon Console → Support → API Clients & Keys
# Scopes mínimos para los scripts: Hosts: Read, Hosts: Write
CS_CLIENT_ID=
CS_CLIENT_SECRET=
CS_BASE_URL=https://api.us-2.crowdstrike.com

# ── Okta ────────────────────────────────────────────────────────────────
# Admin → Security → API → Tokens (token con scope devices/users)
OKTA_DOMAIN=klar.okta.com
OKTA_API_TOKEN=

# ── JumpCloud ───────────────────────────────────────────────────────────
# Settings → API Settings (rol con Systems: read+write)
JC_API_KEY=

# ── Otros (opcionales para los scripts) ─────────────────────────────────
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=
SYNC_INTERVAL_HOURS=6
SYNC_ON_STARTUP=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
JWT_SECRET=generate-a-random-hex-string-here
APP_URL=http://localhost:8080

# ── Okta OIDC (opcional — habilita "Sign in with Okta") ─────────────────
OKTA_OIDC_ISSUER=
OKTA_OIDC_CLIENT_ID=
OKTA_OIDC_CLIENT_SECRET=
OKTA_ALLOWED_DOMAINS=klar.mx
